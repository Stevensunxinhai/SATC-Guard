# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_AUDIO_CHAT_MODEL=gpt-4o-transcribe

# DashScope (Qwen) — use dashscope.aliyuncs.com for China keys, dashscope-intl.aliyuncs.com for intl
DASHSCOPE_API_KEY=sk-...
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_OMNI_MODEL=qwen3.5-omni-plus

# Xiaomi MiMo
MIMO_API_KEY=sk-...
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_ASR_MODEL=mimo-v2.5-asr
MIMO_ASR_LANGUAGE=en

# Data paths
ATCO2_DATA_ROOT=e:/atc-agent/ATCO2-ASRdataset-v1_beta
ATCO2_WAV_DIR=e:/atc-agent/ATCO2-ASRdataset-v1_beta/DATA

# Reproducibility
EXPERIMENT_SEED=42
PROMPT_VERSION=v1.0.0
